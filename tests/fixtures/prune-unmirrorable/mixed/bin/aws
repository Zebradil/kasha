#!/usr/bin/env bash
# Fake aws for the prune fixture. Three manifests under roots/znix/:
#   nullroot -> null drvPath          (class 1, delete)
#   absent   -> drv narinfo missing   (class 2, delete)
#   present  -> drv narinfo present   (keep)
set -euo pipefail
# Skip global options (--endpoint-url VALUE, --region VALUE) that precede the
# subcommand, the same shape mirror-down/prune build from the S3 target.
while [[ $# -gt 0 && "$1" == --* ]]; do shift 2; done
sub="$1"; shift
case "$sub" in
s3api)
  action="$1"; shift
  case "$action" in
  list-objects-v2)
    printf '{"Contents":[{"Key":"%s"},{"Key":"%s"},{"Key":"%s"}]}\n' \
      roots/znix/nullroot.json roots/znix/absent.json roots/znix/present.json
    ;;
  head-object)
    key=""
    while [[ $# -gt 0 ]]; do
      [[ "$1" == --key ]] && { key="$2"; shift 2; continue; }
      shift
    done
    [[ "$key" == present.narinfo ]] && exit 0
    exit 1
    ;;
  esac
  ;;
s3)
  action="$1"; shift
  case "$action" in
  cp)
    case "$1" in
    *nullroot.json) echo '{"version":2,"roots":[{"outPath":"/nix/store/o-out","drvPath":null}]}' ;;
    *absent.json)   echo '{"version":2,"roots":[{"outPath":"/nix/store/o-out","drvPath":"/nix/store/absent-x.drv"}]}' ;;
    *present.json)  echo '{"version":2,"roots":[{"outPath":"/nix/store/o-out","drvPath":"/nix/store/present-x.drv"}]}' ;;
    esac
    ;;
  esac
  ;;
esac
